{
  "name": "@oxlayer/cli-keycloak",
  "version": "0.1.0",
  "description": "Keycloak realm and client bootstrapping CLI for OxLayer",
  "type": "module",
  "bin": {
    "keycloak": "./dist/bin/index.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./templates": {
      "types": "./dist/src/templates/index.d.ts",
      "import": "./dist/src/templates/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test src/**/*.unit.test.ts",
    "test:integration": "bun test src/**/*.integration.test.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "zod": "^3.22.0",
    "dotenv": "^16.4.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "cli/keycloak"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  },
  "license": "Apache-2.0"
}
