{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "bin*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "templates",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.template.ts"
  ]
}
