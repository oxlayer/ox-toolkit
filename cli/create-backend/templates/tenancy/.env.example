# Server Configuration
NODE_ENV=development
PORT={{PORT}}
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14318
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:14318
OTEL_SERVICE_NAME={{PROJECT_SLUG}}-api

# Quickwit (Structured Logging)
QUICKWIT_TRACES_INDEX_ID={{PROJECT_SLUG}}-traces
QUICKWIT_URL=http://localhost:7280

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE={{DB_NAME}}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Tenancy Strategy
# Options: shared-database (single DB with tenant_id), per-database (each tenant has own DB)
TENANCY_STRATEGY=shared-database

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Event Bus
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE={{PROJECT_SLUG}}.events

# ClickHouse (Domain Events & Metrics)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default
CLICKHOUSE_ENABLED=false
DOMAIN_EVENTS_ENDPOINT=http://localhost:14318/v1/events
