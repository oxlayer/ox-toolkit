{
  "name": "@oxlayer/mcp",
  "version": "1.0.0",
  "description": "MCP server for OxLayer DDD patterns and capabilities documentation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp": "dist/index.js"
  },
  "scripts": {
    "prebuild": "npx tsx scripts/embed-docs.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --minify",
    "start": "node dist/index.js",
    "dev": "pnpm run build && node dist/index.js",
    "watch": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --watch"
  },
  "keywords": [
    "mcp",
    "oxlayer",
    "ddd",
    "domain-driven-design"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.2",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "mcp_oxlayer"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  }
}
