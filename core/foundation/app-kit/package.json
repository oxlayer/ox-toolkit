{
  "name": "@oxlayer/foundation-app-kit",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/oxlayer/foundation.git"
  },
  "publishConfig": {
    "registry": "http://localhost:4873/"
  },
  "description": "Application layer primitives: use cases, Result/Either types, and DTO conventions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./use-cases": {
      "types": "./dist/use-cases/index.d.ts",
      "import": "./dist/use-cases/index.js"
    },
    "./result": {
      "types": "./dist/result/index.d.ts",
      "import": "./dist/result/index.js"
    },
    "./mappers": {
      "types": "./dist/mappers/index.d.ts",
      "import": "./dist/mappers/index.js"
    }
  },
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oxlayer/foundation-domain-kit": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "1.3.6",
    "tsup": "latest",
    "typescript": "^5.9.3"
  }
}
