{
  "extends": "../../../tsconfig.frontend.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "***.spec.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.template.ts",
    "src/workspace/**",
    "src/sync/conflict-resolver.ts",
    "src/persist/sqlite-wasm/**"
  ]
}
