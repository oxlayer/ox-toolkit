{
  "extends": "../../../tsconfig.frontend.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "***.spec.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.template.ts"
  ]
}
