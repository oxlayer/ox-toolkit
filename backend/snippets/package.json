{
  "name": "@oxlayer/snippets",
  "version": "0.1.0",
  "description": "Reusable code templates for OxLayer microservices",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./domain": "./dist/index.js",
    "./use-cases": "./dist/index.js",
    "./repositories": "./dist/index.js",
    "./controllers": "./dist/index.js",
    "./config": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@oxlayer/foundation-domain-kit": "workspace:*",
    "@oxlayer/foundation-app-kit": "workspace:*",
    "@oxlayer/foundation-http-kit": "workspace:*",
    "@oxlayer/capabilities-events": "workspace:*",
    "@oxlayer/capabilities-telemetry": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^3.22.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "latest",
    "typescript": "latest"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "backend/snippets"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  },
  "license": "Apache-2.0"
}
