{
  "name": "@oxlayer/pro",
  "private": true,
  "description": "Proprietary layer for the Oxlayer platform",
  "type": "module",
  "scripts": {
    "build:packages": "pnpm --filter '@oxlayer/pro-*' build",
    "bump:packages": "pnpm --filter '@oxlayer/pro-*' exec pnpm version patch",
    "publish:packages": "pnpm --filter '@oxlayer/pro-*' publish --registry http://localhost:4873/ --no-git-checks",
    "dev": "bun --hot",
    "typecheck": "echo workspace-root",
    "clean": "rm -rf */dist */tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
