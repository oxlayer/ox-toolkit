  },
  "peerDependencies": {},
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "backend/pro/adapters/database/postgres-tenancy"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
