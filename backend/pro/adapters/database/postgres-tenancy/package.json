{
  "name": "@oxlayer/pro-adapters-postgres-tenancy",
  "version": "0.1.0",
  "description": "PostgreSQL tenancy adapter for multi-tenant database resolution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oxlayer/pro-tenancy": "workspace:*",
    "@oxlayer/capabilities-internal": "workspace:*",
    "drizzle-orm": "^0.29.0",
