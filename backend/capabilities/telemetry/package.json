{
  "name": "@oxlayer/capabilities-telemetry",
  "version": "0.1.0",
  "description": "OpenTelemetry integration middleware for Hono",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.1",
    "@opentelemetry/auto-instrumentations-node": "0.67.3",
    "@opentelemetry/exporter-logs-otlp-grpc": "0.57.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.57.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.210.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.210.0",
    "@opentelemetry/resources": "2.4.0",
    "@opentelemetry/sdk-logs": "0.57.1",
    "@opentelemetry/sdk-metrics": "^2.4.0",
    "@opentelemetry/sdk-node": "0.210.0",
    "@opentelemetry/sdk-trace-node": "2.4.0",
    "@opentelemetry/semantic-conventions": "1.38.0",
    "hono": "4.11.4",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "backend/capabilities/telemetry"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  },
  "license": "Apache-2.0"
}
