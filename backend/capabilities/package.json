{
  "name": "@oxlayer/capabilities",
  "description": "Core capabilities staples for backend",
  "type": "module",
  "scripts": {
    "build:packages": "pnpm --filter '@oxlayer/capabilities-*' build",
    "bump:packages": "pnpm --filter '@oxlayer/capabilities-*' exec pnpm version patch",
    "publish:packages": "pnpm --filter '@oxlayer/capabilities-*' publish --registry http://localhost:4873/ --no-git-checks",
    "dev": "bun --hot",
    "typecheck": "echo workspace-root",
    "clean": "rm -rf */dist */tsconfig.tsbuildinfo adapters/*/dist"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "latest",
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "backend/capabilities"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  },
  "license": "Apache-2.0",
  "version": "0.1.0"
}
