{
  "name": "@oxlayer/capabilities-adapters-mongo",
  "version": "1.0.3",
  "description": "MongoDB adapter for @oxlayer/capabilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oxlayer/capabilities-internal": "workspace:*",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
