{
  "name": "@oxlayer/backend",
  "version": "0.1.0",
  "workspaces": [
    "foundation",
    "capabilities",
    "examples"
  ],
  "scripts": {
    "clean": "pnpm -r exec rm -rf dist",
    "build:all": "pnpm -r build",
    "rebuild": "pnpm run clean && pnpm run build:all",
    "rebuild:ordered": "pnpm run clean && pnpm run build:cli && pnpm run build:foundation && pnpm run build:capabilities && pnpm run build:proprietary && pnpm run build:snippets && pnpm run build:examples",
    "build:cli": "pnpm --filter '@oxlayer/cli-*' build",
    "build:foundation": "pnpm --filter '@oxlayer/foundation-*' build",
    "build:capabilities": "pnpm --filter '@oxlayer/capabilities-*' --filter \"@oxlayer/capabilities-web\" run build",
    "build:proprietary": "pnpm --filter '@oxlayer/pro-*' build",
    "build:snippets": "pnpm --filter '@oxlayer/snippets*' build",
    "build:examples": "pnpm --filter '@oxlayer/examples-*' build"
  },
  "devDependencies": {
    "@types/node": "25.0.10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxlayer/ox-toolkit.git",
    "directory": "backend"
  },
  "homepage": "https://github.com/oxlayer/ox-toolkit#readme",
  "bugs": {
    "url": "https://github.com/oxlayer/ox-toolkit/issues"
  },
  "license": "Apache-2.0"
}
