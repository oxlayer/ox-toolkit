# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=DEBUG

# PostgreSQL Database - using oxlayer-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=fator_h
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PostgreSQL Admin Database (Control Panel) - dedicated database for realm registry
POSTGRES_ADMIN_HOST=localhost
POSTGRES_ADMIN_PORT=5432
POSTGRES_ADMIN_DATABASE=globex_admin
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres

# Redis Cache - using oxlayer-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ Event Bus - using oxlayer-rabbitmq
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=globex.events

# Keycloak Authentication - using oxlayer-keycloak
KEYCLOAK_ENABLED=true
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=globex
KEYCLOAK_CLIENT_ID=globex-api

# Bitwarden Secrets Manager (optional)
BITWARDEN_ENABLED=false
BITWARDEN_URL=https://api.bitwarden.com
# BITWARDEN_TOKEN=your_token

JWT_SECRET=secret123

# Admin API Key (for tenant provisioning endpoints)
ADMIN_API_KEY=admin-secret-change-in-production
