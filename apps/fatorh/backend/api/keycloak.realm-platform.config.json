{
  "keycloak": {
    "url": "http://localhost:8080",
    "admin": {
      "username": "admin",
      "password": "admin"
    }
  },
  "realm": {
    "name": "globex-platform",
    "displayName": "Fator H Platform Realm",
    "type": "platform",
    "sslRequired": "none",
    "security": {
      "loginWithEmailAllowed": true,
      "registrationEmailAsUsername": false,
      "duplicateEmailsAllowed": false,
      "resetPasswordAllowed": true,
      "bruteForceProtected": true
    }
  },
  "clients": [
    {
      "name": "platform-admin",
      "template": "admin-client",
      "overrides": {
        "description": "Platform admin panel",
        "redirectUris": [
          "http://localhost:3000/*"
        ],
        "webOrigins": [
          "http://localhost:3000"
        ],
        "validPostLogoutRedirectUris": [
          "http://localhost:3000"
        ]
      }
    },
    {
      "name": "example-admin",
      "template": "web-client",
      "overrides": {
        "description": "FatorH Tenant Management Admin Portal",
        "publicClient": true,
        "redirectUris": [
          "http://localhost:5175/*"
        ],
        "webOrigins": [
          "http://localhost:5175"
        ],
        "validPostLogoutRedirectUris": [
          "http://localhost:5175"
        ]
      }
    }
  ],
  "roles": [
    {
      "name": "platform-admin",
      "description": "Platform administrator with full access to tenant provisioning"
    },
    {
      "name": "platform-support",
      "description": "Platform support staff"
    },
    {
      "name": "platform-ops",
      "description": "Platform operations team"
    }
  ]
}