{
  "name": "@oxlayer/ox-globex-api",
  "version": "1.0.0",
  "description": "Fator-H API using oxlayer DDD architecture - Exams, evaluations, programs, users, workspaces",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "tsup",
    "start": "bun dist/server.js",
    "keycloak:bootstrap": "node ../../../../core/cli/keycloak-bootstrap/dist/bin/index.js bootstrap --config keycloak.realm-platform.config.json",
    "keycloak:bootstrap2": "node ../../../../core/cli/keycloak-bootstrap/dist/bin/index.js bootstrap --config keycloak.realm-client.config.json",
    "keycloak:init": "node ../../../../core/cli/keycloak-bootstrap/dist/bin/index.js init --output keycloak.config.json",
    "keycloak:validate": "node ../../../../core/cli/keycloak-bootstrap/dist/bin/index.js validate --config keycloak.config.json",
    "db:init": "bun src/db/init.ts",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "test": "bun test",
    "test:unit": "bun test src/**/*.unit.test.ts",
    "test:integration": "bun test src/**/*.integration.test.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.943.0",
    "@hono/zod-validator": "^0.4.0",
    "@oxlayer/capabilities-adapters-postgres": "workspace:*",
    "@oxlayer/capabilities-adapters-rabbitmq": "workspace:*",
    "@oxlayer/capabilities-adapters-redis": "workspace:*",
    "@oxlayer/capabilities-auth": "workspace:*",
    "@oxlayer/capabilities-cache": "workspace:*",
    "@oxlayer/capabilities-events": "workspace:*",
    "@oxlayer/capabilities-internal": "workspace:*",
    "@oxlayer/capabilities-telemetry": "workspace:*",
    "@oxlayer/capabilities-openapi": "workspace:*",
    "@oxlayer/cli-keycloak-bootstrap": "workspace:*",
    "@oxlayer/foundation-app-kit": "workspace:*",
    "@oxlayer/foundation-domain-kit": "workspace:*",
    "@oxlayer/foundation-http-kit": "workspace:*",
    "@oxlayer/foundation-persistence-kit": "workspace:*",
    "@oxlayer/foundation-testing-kit": "workspace:*",
    "@oxlayer/pro-adapters-postgres-tenancy": "workspace:*",
    "@oxlayer/pro-tenancy": "workspace:*",
    "cpf-cnpj-validator": "1.0.3",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa":"3.2.2",
    "csv-parse": "6.1.0",
    "dotenv": "17.2.3",
    "drizzle-orm": "0.44.7",
    "hono": "^4.6.0",
    "ioredis": "^5.9.2",
    "postgres": "3.4.7",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "latest",
    "typescript": "latest"
  },
  "engines": {
    "pnpm": ">=1.0.0"
  }
}
