# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Keycloak Authentication
KEYCLOAK_ENABLED=true
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=oxlayer
KEYCLOAK_CLIENT_ID=todo-app

# Keycloak Bootstrap (CLI - for realm/client creation)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
FRONTEND_URL=http://localhost:3000

# JWT Fallback (for development without Keycloak)
JWT_SECRET=your-secret-key-change-in-production

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=todo_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Event Bus
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=todo.events

# Bitwarden Secrets (Optional)
BITWARDEN_ENABLED=false
BITWARDEN_TOKEN=
BITWARDEN_URL=https://api.bitwarden.com

# ========================================
# Observability - OpenTelemetry (Split Collectors)
# ========================================
# See: COLLECTOR_SPLIT_GUIDE.md for architecture details

# Collector A: Observability (logs + traces) → Quickwit
# Both logs and traces use HTTP exporter (port 14318)
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:14318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:14318
OTEL_SERVICE_NAME=todo-app

# Collector B: Domain Events (business events) → ClickHouse
DOMAIN_EVENTS_ENDPOINT=http://localhost:24317

# Observability - Quickwit Direct Access
QUICKWIT_URL=http://localhost:7280
QUICKWIT_LOGS_INDEX_ID=todo-app-logs
QUICKWIT_TRACES_INDEX_ID=todo-app-traces
QUICKWIT_API_KEY=

# Observability - ClickHouse Direct Access
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=analytics

# Application Logging
LOG_LEVEL=INFO
