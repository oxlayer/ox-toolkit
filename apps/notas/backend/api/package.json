{
  "name": "@oxlayer/example-todo-app",
  "version": "1.0.0",
  "description": "Todo CRUD app with Keycloak auth, PostgreSQL, Redis, and RabbitMQ",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "keycloak:bootstrap": "node ../../cli/keycloak-bootstrap/dist/bin/index.js bootstrap --config keycloak.config.json",
    "keycloak:init": "node ../../cli/keycloak-bootstrap/dist/bin/index.js init --output keycloak.config.json",
    "keycloak:validate": "node ../../cli/keycloak-bootstrap/dist/bin/index.js validate --config keycloak.config.json",
    "test": "bun test",
    "test:unit": "bun test ./src/**/*.unit.test.ts",
    "test:integration": "bun test ./src/**/*.integration.test.ts",
    "test:concurrency": "bun test ./src/**/*.concurrency.test.ts",
    "test:coverage": "bun test --coverage",
    "perf:quick": "k6 run perf-tests/quick-test.js",
    "perf:load": "k6 run perf-tests/load-test.js",
    "perf:spike": "k6 run perf-tests/spike-test.js",
    "perf:soak": "k6 run perf-tests/soak-test.js",
    "perf:report": "k6 run --out html=perf-tests/report.html perf-tests/load-test.js"
  },
  "dependencies": {
    "@oxlayer/foundation-app-kit": "workspace:*",
    "@oxlayer/foundation-domain-kit": "workspace:*",
    "@oxlayer/foundation-http-kit": "workspace:*",
    "@oxlayer/foundation-persistence-kit": "workspace:*",
    "@oxlayer/foundation-testing-kit": "workspace:*",
    "@oxlayer/capabilities-adapters-postgres": "workspace:*",
    "@oxlayer/capabilities-adapters-redis": "workspace:*",
    "@oxlayer/capabilities-adapters-rabbitmq": "workspace:*",
    "@oxlayer/capabilities-adapters-bitwarden-secrets": "workspace:*",
    "@oxlayer/capabilities-auth": "workspace:*",
    "@oxlayer/capabilities-cache": "workspace:*",
    "@oxlayer/capabilities-events": "workspace:*",
    "@oxlayer/capabilities-internal": "workspace:*",
    "@oxlayer/capabilities-openapi": "workspace:*",
    "@oxlayer/capabilities-telemetry": "workspace:*",
    "@oxlayer/capabilities-testing": "workspace:*",
    "@oxlayer/snippets": "workspace:*",
    "drizzle-orm": "0.45.1",
    "postgres": "3.4.8",
    "hono": "4.11.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/bun": "1.3.6",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}