{
  "keycloak": {
    "url": "${KEYCLOAK_URL:-http://localhost:8080}",
    "admin": {
      "username": "${KEYCLOAK_ADMIN:-admin}",
      "password": "${KEYCLOAK_ADMIN_PASSWORD:-admin}"
    }
  },
  "realm": {
    "name": "oxlayer",
    "displayName": "OxLayer Platform",
    "type": "shared"
  },
  "clients": [
    {
      "name": "todo-app-api",
      "template": "api-client",
      "overrides": {
        "description": "Todo App Backend API"
      }
    },
    {
      "name": "todo-app-web",
      "template": "web-client",
      "overrides": {
        "description": "Todo App Web Frontend",
        "redirectUris": [
          "http://localhost:3000/*",
          "http://localhost:3001/*",
          "http://localhost:3002/*",
          "http://localhost:3003/*"
        ],
        "validPostLogoutRedirectUris": [
          "http://localhost:3000",
          "http://localhost:3001",
          "http://localhost:3002",
          "http://localhost:3003"
        ],
        "webOrigins": [
          "http://localhost:3000",
          "http://localhost:3001",
          "http://localhost:3002",
          "http://localhost:3003"
        ]
      }
    }
  ],
  "roles": [
    {
      "name": "user",
      "description": "Standard todo app user"
    },
    {
      "name": "admin",
      "description": "Todo app administrator"
    }
  ],
  "protocolMappers": [
    {
      "name": "organization-id-mapper",
      "protocol": "openid-connect",
      "protocolMapper": "oidc-usermodel-attribute-mapper",
      "clients": [
        "todo-app-web",
        "todo-app-api"
      ],
      "config": {
        "access.token.claim": "true",
        "claim.name": "organization",
        "jsonType.label": "JSON",
        "introspection.token.claim": "true",
        "multivalued": "true",
        "userinfo.token.claim": "true",
        "id.token.claim": "true",
        "addOrganizationId": "true"
      }
    }
  ]
}