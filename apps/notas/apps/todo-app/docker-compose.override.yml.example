# Docker Compose Override Example
# Copy this file to docker-compose.override.yml and customize for your local development

services:
  # Override todo-app service for local development
  todo-app:
    # Mount local source code for hot reload
    volumes:
      - .:/app
      - /app/node_modules

    # Override environment variables for development
    environment:
      - NODE_ENV=development
      - KEYCLOAK_ENABLED=false  # Disable Keycloak for easier local testing

    # Add service dependencies
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  # Add admin service for database management
  adminer:
    image: adminer:latest
    container_name: oxlayer-adminer
    ports:
      - "8081:8080"
    networks:
      - oxlayer-network

  # Add mailhog for email testing (if needed)
  mailhog:
    image: mailhog/mailhog:latest
    container_name: oxlayer-mailhog
    ports:
      - "1025:1025"  # SMTP
      - " "8025:8025"  # Web UI
    networks:
      - oxlayer-network
