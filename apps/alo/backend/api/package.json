{
  "name": "@acme/api",
  "version": "1.0.0",
  "description": "Alo Manager API - Establishments, Users, Service Providers, Delivery Men management with Keycloak auth, PostgreSQL, Redis, and RabbitMQ",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "test": "bun test",
    "test:unit": "bun test ./src/**/*.unit.test.ts",
    "test:integration": "bun test ./src/**/*.integration.test.ts",
    "test:coverage": "bun test --coverage",
    "keycloak": "bun node_modules/@oxlayer/cli-keycloak-bootstrap/bin/index.ts bootstrap --config keycloak.config.json"
  },
  "dependencies": {
    "@oxlayer/capabilities-adapters-postgres": "workspace:*",
    "@oxlayer/capabilities-adapters-rabbitmq": "workspace:*",
    "@oxlayer/capabilities-adapters-redis": "workspace:*",
    "@oxlayer/capabilities-auth": "workspace:*",
    "@oxlayer/capabilities-cache": "workspace:*",
    "@oxlayer/capabilities-events": "workspace:*",
    "@oxlayer/capabilities-internal": "workspace:*",
    "@oxlayer/capabilities-metrics": "workspace:*",
    "@oxlayer/capabilities-openapi": "workspace:*",
    "@oxlayer/capabilities-telemetry": "workspace:*",
    "@oxlayer/capabilities-testing": "workspace:*",
    "@oxlayer/foundation-app-kit": "workspace:*",
    "@oxlayer/foundation-domain-kit": "workspace:*",
    "@oxlayer/foundation-http-kit": "workspace:*",
    "@oxlayer/foundation-persistence-kit": "workspace:*",
    "@oxlayer/foundation-testing-kit": "workspace:*",
    "@oxlayer/snippets": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "0.45.1",
    "hono": "4.11.4",
    "postgres": "3.4.8",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@oxlayer/cli-keycloak-bootstrap": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "1.3.6",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.31.8",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}