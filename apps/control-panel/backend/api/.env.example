PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oxlayer_control_panel
# Generate with: openssl rand -hex 32
OXLAYER_ENCRYPTION_KEY=replace-with-random-uuid-or-32-byte-hex
MIDDLEWARE_DEV_MODE=true

ENABLE_KEYCLOAK=true
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=oxlayer
KEYCLOAK_CLIENT_ID=oxlayer-api
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-secret

# R2/S3 Configuration for SDK package storage
R2_REGION=auto

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-password

# Seed data for local development
SEED_ORG_ID=00000000-0000-0000-0000-000000000001
SEED_DEV_ID=00000000-0000-0000-0000-000000000002
SEED_DEV_EMAIL=dev@example.com
SEED_DEV_NAME=Admin
SEED_LICENSE_DAYS=365
SEED_SDK_VERSION=2026_02_14_001
