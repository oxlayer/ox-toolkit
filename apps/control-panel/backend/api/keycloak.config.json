{
  "keycloak": {
    "url": "http://localhost:8080",
    "admin": {
      "username": "admin",
      "password": "admin"
    }
  },
  "realm": {
    "name": "oxlayer",
    "displayName": "OxLayer Application",
    "type": "client",
    "security": {
      "loginWithEmailAllowed": true,
      "duplicateEmailsAllowed": false,
      "resetPasswordAllowed": true,
      "editUsernameAllowed": false,
      "bruteForceProtected": true,
      "permanentLockout": false
    }
  },
  "clients": [
    {
      "name": "oxlayer-api",
      "template": "api-client",
      "overrides": {
        "description": "Backend API client for OxLayer",
        "redirectUris": [
          "http://localhost:3001/*"
        ],
        "webOrigins": [
          "http://localhost:3001"
        ],
        "clientSecret": "oxlayer-api-secret"
      }
    },
    {
      "name": "oxlayer-admin",
      "template": "web-client",
      "overrides": {
        "description": "OxLayer Tenant Management Admin Portal",
        "publicClient": true,
        "redirectUris": [
          "http://localhost:5173/*"
        ],
        "webOrigins": [
          "http://localhost:5173"
        ],
        "validPostLogoutRedirectUris": [
          "http://localhost:5173"
        ]
      }
    },
    {
      "name": "oxlayer-manager",
      "template": "admin-client",
      "overrides": {
        "description": "Platform admin panel",
        "redirectUris": [
          "http://localhost:5174/*"
        ],
        "webOrigins": [
          "http://localhost:5174"
        ],
        "validPostLogoutRedirectUris": [
          "http://localhost:5174"
        ]
      }
    }
  ],
  "roles": [
    {
      "name": "admin",
      "description": "OxLayer administrator"
    },
    {
      "name": "owner",
      "description": "Organization owner"
    },
    {
      "name": "developer",
      "description": "Organization development user"
    }
  ]
}