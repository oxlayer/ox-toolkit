#!/usr/bin/env node

/**
 * OxLayer Runtime Wrapper
 *
 * Loads secrets from Bitwarden and injects them as environment variables
 * before running the specified command.
 *
 * Usage:
 *   oxlayer -e .env -r pnpm dev
 *   oxlayer -r pnpm dev
 *   oxlayer pnpm dev
 */

import { spawn } from 'child_process';
import { readFile, stat } from 'fs/promises';
import { resolve, dirname } from 'path';
import { fileURLToPath } from 'url';
import { parseArgs } from 'util';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

interface CliArgs {
  e?: string;
  env?: string;
  r?: string;
  run?: string;
  _: string[];
}

/**
 * Parse command line arguments
 */
function parseCliArgs(): { envFile?: string; command: string[] } {
  const args = parseArgs({
    options: {
      e: { type: 'string' },
      env: { type: 'string' },
      r: { type: 'string' },
      run: { type: 'string' },
    },
    allowPositionals: true,
  });

  const envFile = args.e || args.env;
  const command = args.r || args.run || args._;

  if (typeof command === 'string') {
    return { envFile, command: [command] };
  }
  if (Array.isArray(command) && command.length > 0) {
    return { envFile, command };
  }

  console.error('Usage: oxlayer [-e .env] [-r] <command> [args...]');
  console.error('  -e, --env   Load additional environment file');
  console.error('  -r, --run   Command to run (defaults to first positional)');
  process.exit(1);
}

/**
 * Check if bw (Bitwarden CLI) is available
 */
async function checkBitwardenCli(): Promise<boolean> {
  const result = await spawn('bw', ['--version'], {
    shell: true,
    stdio: 'pipe',
  });
  return !result.error;
}

/**
 * Run command with Bitwarden secrets injection
 *
 * This uses `bw run` to inject secrets from Bitwarden vault
 * as environment variables before running the target command.
 */
async function runWithSecrets(command: string[], envFile?: string): Promise<void> {
  const args = ['run', '--'];

  // Add --env-file if specified
  if (envFile) {
    args.push('--env-file', envFile);
  }

  // Add the command to run
  args.push(...command);

  console.log(`🔐 Loading secrets from Bitwarden...`);
  console.log(`   Running: ${command.join(' ')}`);

  const child = spawn('bw', args, {
    stdio: 'inherit',
    shell: true,
    env: {
      ...process.env,
      BW_SESSION: process.env.BW_SESSION,
    },
  });

  return new Promise((resolve, reject) => {
    child.on('close', (code) => {
      if (code === 0) {
        resolve();
      } else {
        reject(new Error(`Command exited with code ${code}`));
      }
    });
    child.on('error', reject);
  });
}

/**
 * Run command directly (without Bitwarden)
 */
async function runDirect(command: string[], envFile?: string): Promise<void> {
  // If env file is specified, load it manually
  if (envFile) {
    const fs = await import('fs/promises');
    try {
      const content = await fs.readFile(envFile, 'utf-8');
      const envVars: Record<string, string> = {};

      for (const line of content.split('\n')) {
        const trimmed = line.trim();
        if (!trimmed || trimmed.startsWith('#')) continue;

        const [key, ...valueParts] = trimmed.split('=');
        if (key && valueParts.length > 0) {
          envVars[key] = valueParts.join('=');
        }
      }

      // Merge with existing env
      Object.assign(process.env, envVars);
      console.log(`📄 Loaded environment from: ${envFile}`);
    } catch (err) {
      console.warn(`⚠️  Could not load env file: ${(err as Error).message}`);
    }
  }

  console.log(`   Running: ${command.join(' ')}`);

  const [cmd, ...args] = command;
  const child = spawn(cmd, args, {
    stdio: 'inherit',
    shell: true,
    env: process.env,
  });

  return new Promise((resolve, reject) => {
    child.on('close', (code) => {
      if (code === 0) {
        resolve();
      } else {
        reject(new Error(`Command exited with code ${code}`));
      }
    });
    child.on('error', reject);
  });
}

/**
 * Main entry point
 */
async function main(): Promise<void> {
  const { envFile, command } = parseCliArgs();

  // Check if Bitwarden CLI is available
  const hasBitwarden = await checkBitwardenCli();

  if (hasBitwarden) {
    try {
      await runWithSecrets(command, envFile);
    } catch (err) {
      console.error(`✖ Failed to run with Bitwarden: ${(err as Error).message}`);
      process.exit(1);
    }
  } else {
    console.warn('⚠️  Bitwarden CLI not found, running without secrets injection');
    console.warn('   Install: npm install -g @bitwarden/cli');
    try {
      await runDirect(command, envFile);
    } catch (err) {
      console.error(`✖ Failed to run: ${(err as Error).message}`);
      process.exit(1);
    }
  }
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
