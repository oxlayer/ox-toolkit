    "expiresAt": {
      "type": "string",
      "nullable": true,
      "format": "date-time",
      "example": "2026-01-01T00:00:00Z"
    },
    "lastUsedAt": {
      "type": "string",
      "nullable": true,
      "format": "date-time",
      "example": "2025-01-01T12:00:00Z"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "organizationId",
    "developerId",
    "licenseId",
    "name",
    "keyPrefix",
    "keyPreview",
    "scopes",
    "status",
    "expiresAt",
