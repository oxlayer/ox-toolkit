{
  "name": "oxlayer",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.2.13",
  "workspaces": [
    "apps/*",
    "apps/*/backend/*",
    "apps/*/frontend/*",
    "apps/*/packages/*",
    "backend",
    "backend/foundation",
    "backend/foundation/*",
    "backend/capabilities",
    "backend/capabilities/*",
    "backend/capabilities/adapters/*",
    "backend/capabilities/adapters/*/*",
    "backend/capabilities/telemetry/*",
    "backend/pro",
    "backend/pro/tenancy",
    "backend/pro/adapters/*/*",
    "backend/pro/adapters/storage/s3/*",
    "backend/snippets",
    "channels/*",
    "cli/*",
    "frontend",
    "frontend/capabilities-web/*",
    "frontend/packages/@*/*",
    "mcp_oxlayer",
    "docs/*"
  ],
  "scripts": {
    "infra": "cd ./infra_oxlayer && docker-compose up -d",
    "keycloak": "node ./apps/control-panel/backend/api/node_modules/@oxlayer/cli-keycloak/dist/bin/index.js bootstrap --config ./apps/control-panel/backend/api/keycloak.config.json",
    "panel": "bun --filter @oxlayer/control-panel-dashboard dev",
    "panel:api": "bun --filter @oxlayer/control-panel-api dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "backend": "turbo run build --filter='./backend/**' --filter='!./backend/release/**'",
    "backend:release": "cd ./backend && ./release.sh",
    "frontend": "turbo run build --filter='./frontend/**' --filter='!./frontend/release/**'",
    "frontend:release": "cd ./frontend && ./release.sh",
    "cli": "turbo run build --filter='./cli/**' --filter='!./cli/release/**'",
    "cli:release": "cd ./cli && ./release.sh",
    "channels": "turbo run build --filter='./channels/**' --filter='!./channels/release/**'",
    "channels:release": "cd ./channels && ./release.sh",
    "sdk:build-scripts": "tsup --config scripts/sdk-release/tsup.config.ts",
    "sdk:version": "node scripts/sdk-release/dist/generate-version.js",
    "sdk:manifest": "node scripts/sdk-release/dist/generate-manifest.js",
    "sdk:release": "bun run sdk:build-scripts && node scripts/sdk-release/dist/generate-manifest.js $(bun run sdk:version)",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.10",
    "esbuild": "^0.27.2",
    "eslint": "^9.20.0",
    "lefthook": "^1.10.10",
    "oxlint": "^0.15.13",
    "tsup": "^8.3.5",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "trustedDependencies": [
    "electron",
    "es5-ext",
    "esbuild",
    "msgpackr-extract",
    "protobufjs"
  ],
  "overrides": {
    "ora": "^5.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
